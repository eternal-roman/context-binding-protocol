# =============================================================================
# Context Binding Protocol — .gitignore
# =============================================================================
# Principle: this repository holds specifications, governance, and provenance.
# Anything that is ephemeral, secret, environment-specific, or generated from
# source artifacts should stay out.
# =============================================================================

# --- Secrets & credentials ---------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/
*.secret
*credentials*.json

# --- OS cruft ----------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Editors & IDEs ----------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.vs/

# --- Claude Code & AI tooling ------------------------------------------------
.claude/*
!.claude/settings.json
!.claude/commands/
.aider*
.cursor/

# --- Logs & temp -------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.orig

# --- Language ecosystems (future-proofing; repo is spec-only today) ---------
# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/
.next/
.turbo/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Go
*.exe
*.test
*.out
vendor/

# Rust
target/
Cargo.lock.bak

# --- Build & coverage --------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# --- Local working notes -----------------------------------------------------
NOTES.local.md
SCRATCH.md
*.drafts/

# --- AI planning / design specs (transient — keep local, never commit to a PR) -
docs/superpowers/
