        "tags": ["signal:regime"],
        "v": 1,
        "prev": null
      }
    ],
    "edges": [
      {
        "id": "f1a2b3c4",
        "src": "a7c3f1e2",
        "tgt": "d4e5f6a7",
        "rel": "correlates",
