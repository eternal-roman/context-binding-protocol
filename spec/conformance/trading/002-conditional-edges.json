  "operations": [
    {
      "op": "resolve",
      "description": "With regime=risk_on, the BTC-ETH correlates edge should be ACTIVE",
      "params": {},
      "expected": {
        "nodes": [
          { "id": "f0d2e8a1" },
          { "id": "a7c3f1e2" },
          { "id": "d4e5f6a7" },
          { "id": "e5f6a7b8" }
        ],
        "edges": [
          {
            "id": "f1a2b3c4",
            "src": "a7c3f1e2",
            "tgt": "d4e5f6a7",
