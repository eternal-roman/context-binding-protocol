{
  "vector_id": "trading-002-conditional-edges",
  "version": "0.3",
  "domain": "trading",
  "description": "Conditional edge activation based on regime prior. BTC-ETH correlation edge is active when regime=risk_on, dormant when regime=risk_off. Tests both states.",
