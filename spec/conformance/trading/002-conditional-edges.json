      "max_token_budget": 400,
      "inheritance_mode": "prototypal",
      "conditional_edge_eval": "eager",
      "tokenizer": "o200k_base"
    },
    "nodes": [
      {
        "id": "f0d2e8a1",
        "type": "frame",
        "val": { "name": "crypto_macro" },
        "w": 1.0,
        "decay": "epoch",
        "ttl": null,
        "lineage": null,
        "tags": ["domain:trading"],
        "v": 1,
        "prev": null
      },
      {
        "id": "a7c3f1e2",
        "type": "entity",
        "val": "BTC",
        "w": 0.9,
        "decay": "epoch",
