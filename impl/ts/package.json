{
  "name": "@cbp/reference",
  "version": "0.13.0",
  "description": "CBP reference implementation — TypeScript",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts",
    "demo": "tsx demo/quickstart.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "typecheck": "tsc --noEmit",
    "conformance": "vitest run test/conformance/"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "@noble/hashes": "^1.7.0",
    "fastify": "^5.8.4",
    "js-tiktoken": "^1.0.18",
    "pino": "^10.3.1",
    "re2": "^1.24.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.17.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "re2",
      "esbuild"
    ]
  }
}
